<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_dashboard_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OmniConverter"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/oc_secondary_dark"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:background="@drawable/bg_chip_surface"
            android:layout_marginBottom="12dp"
            android:fontFamily="serif" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Convert anything, anywhere"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/oc_primary_dark"
            android:layout_marginBottom="4dp"
            android:fontFamily="serif" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Choose a tool category below and start converting in seconds."
            android:textSize="14sp"
            android:textColor="@color/oc_text_secondary"
            android:layout_marginBottom="16dp"
            android:fontFamily="serif" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tip: stay on this screen to monitor progress while a conversion runs."
            android:textSize="12sp"
            android:textColor="@color/oc_text_secondary"
            android:fontFamily="serif" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="12dp"
        android:layout_marginTop="8dp"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:strokeColor="@color/oc_soft_green"
        app:strokeWidth="2dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/converter_list_recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="12dp"
            android:scrollbars="vertical" />

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
