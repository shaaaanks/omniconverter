<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_gradient_background">

    <!-- Main Content Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <!-- Logo Badge Container -->
        <FrameLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginBottom="32dp">

            <!-- Dark Badge Background -->
            <ImageView
                android:id="@+id/logo_badge_bg"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:background="@drawable/logo_badge_background"
                android:contentDescription="@string/app_logo" />

            <!-- Rotating Conversion Icon -->
            <ImageView
                android:id="@+id/conversion_icon"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_conversion_icon"
                android:contentDescription="@string/conversion_icon"
                android:tint="#8EB69B" />

            <!-- Pulsing Glow Effect -->
            <View
                android:id="@+id/glow_effect"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:background="@drawable/logo_glow_effect" />

        </FrameLayout>

        <!-- App Name -->
        <TextView
            android:id="@+id/app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#051F20"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/poppins_bold" />

        <!-- Tagline -->
        <TextView
            android:id="@+id/tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/splash_tagline"
            android:textSize="14sp"
            android:textColor="#235347"
            android:alpha="0.8"
            android:layout_marginBottom="48dp"
            android:fontFamily="@font/poppins_regular" />

    </LinearLayout>

    <!-- Progress Indicator at Bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingBottom="32dp">

        <!-- Circular Progress Bar -->
        <ProgressBar
            android:id="@+id/progress_indicator"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminate="true"
            android:indeterminateTint="#8EB69B"
            android:indeterminateTintMode="src_in"
            android:layout_marginBottom="16dp" />

        <!-- Status Text -->
        <TextView
            android:id="@+id/status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/initializing"
            android:textSize="12sp"
            android:textColor="#235347"
            android:alpha="0.7"
            android:fontFamily="@font/poppins_regular" />

    </LinearLayout>

</RelativeLayout>
